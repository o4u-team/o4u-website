## Copy to .deploy.env (do not commit) and edit.
## Then run: ./scripts/deploy.sh

# Required
DEPLOY_HOST="116.118.49.239"
DEPLOY_USER="root"
DEPLOY_PATH="/opt/apps/o4u.nvnhan0810.com"

# Optional
# DEPLOY_PORT="22"
# DEPLOY_SSH_KEY="$HOME/.ssh/id_ed25519"

# Optional remote commands to run after upload (executed on VPS in DEPLOY_PATH)
# Examples:
DEPLOY_POST_COMMANDS="composer i && php artisan migrate --force && composer i --no-dev -o && php artisan optimize:clear && php artisan optimize"

# Supervior Post commands
SUPERVISOR_POST_COMMANDS="cp ./deploy/supervisor/o4u-queue-worker.conf /etc/supervisor/conf.d/o4u-queue-worker.conf && supervisorctl reread && supervisorctl update && supervisorctl restart \"o4u-queue-worker:*\""
